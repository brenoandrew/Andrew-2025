---
import Globe from "../components/Globe";
import BasicLayout from "../layouts/BasicLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import { visitedCountries } from "../lib/travel";
---

<BasicLayout
  description="A globe and country list showing the places Andrew Henrice has visited so far."
  page="travel"
  title="Andrew Henrice - Visited Countries"
>
  <SiteNav />
  <main id="content">
    <section class="travel-hero">
      <div class="copy">
        <p class="kicker">Travel</p>
        <h1>{visitedCountries.length} countries and counting.</h1>
        <p>
          A living map of where I have been, with photos from the road collected
          in the gallery.
        </p>
        <a class="text-link" href="/photography">Open photography</a>
      </div>
      <div class="globe-wrap" aria-label="Interactive globe of visited countries">
        <Globe client:load />
      </div>
    </section>

    <section class="country-section" aria-labelledby="countries-title">
      <div>
        <p class="kicker">Atlas</p>
        <h2 id="countries-title">Visited countries</h2>
      </div>
      <ul>
        {visitedCountries.map((country) => <li>{country}</li>)}
      </ul>
    </section>
  </main>
</BasicLayout>

<style>
  main {
    margin: 0 auto;
    max-width: 72rem;
    padding: 0 1rem 2rem;
    width: 100%;
  }

  .travel-hero {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    padding: 4rem 0;
  }

  .kicker {
    font-size: 0.78rem;
    font-weight: 800;
    margin: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.6rem);
    font-weight: 500;
    line-height: 0.9;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 500;
    line-height: 0.95;
    margin-top: 0.55rem;
  }

  .copy p:not(.kicker) {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-top: 1.2rem;
  }

  .text-link {
    border-bottom: 1px solid currentColor;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 800;
    margin-top: 1.35rem;
    text-decoration: none;
  }

  .globe-wrap {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    min-height: 380px;
    overflow: hidden;
  }

  .country-section {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    padding-top: 3rem;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink);
    font-size: 0.9rem;
    padding: 0.48rem 0.72rem;
  }

  @media (max-width: 820px) {
    main {
      padding-bottom: 1.5rem;
    }

    .travel-hero,
    .country-section {
      grid-template-columns: 1fr;
    }

    .travel-hero {
      align-items: start;
      gap: 1.75rem;
      padding: 2.75rem 0 3rem;
    }

    h1 {
      font-size: 3.2rem;
      line-height: 0.92;
    }

    h2 {
      font-size: 2.25rem;
    }

    .copy p:not(.kicker) {
      font-size: 1rem;
      line-height: 1.6;
      margin-top: 1rem;
    }

    .text-link {
      align-items: center;
      min-height: 2.5rem;
    }

    .globe-wrap {
      min-height: 0;
      height: min(22rem, 78vw);
      width: 100%;
    }

    .country-section {
      gap: 1.25rem;
      padding-top: 2.5rem;
    }

    ul {
      gap: 0.5rem;
    }

    li {
      max-width: 100%;
    }
  }
</style>
