---
import { formatDate } from "../../lib/helpers";

interface Props {
  title: string;
  date: Date;
  id: string;
}

const { title, date, id } = Astro.props;
---

<li class="post-row">
  <a href={`/blog/${id}`}>
    <span>{title}</span>
    <time data-date={date.toISOString()} datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </a>
</li>

<style>
  .post-row {
    list-style: none;
  }

  .post-row a {
    align-items: center;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 1rem 0;
    text-decoration: none;
  }

  .post-row a:hover span {
    color: var(--ink-muted);
  }

  span {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 800;
  }

  time {
    color: var(--ink-muted);
    flex: 0 0 auto;
    font-size: 0.86rem;
    tab-size: 4;
  }

  @media (max-width: 620px) {
    .post-row a {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
      min-height: 4.25rem;
      padding: 1rem 0;
    }

    span {
      line-height: 1.25;
    }
  }
</style>
