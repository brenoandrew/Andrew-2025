---
import { navigation, profile } from "../lib/profile";
---

<footer class="site-footer">
  <div class="footer-inner">
    <nav aria-label="Footer navigation" class="footer-nav">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="footer-email" href={profile.emailHref}>{profile.email}</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--inverse);
    color: var(--inverse-ink);
    margin-top: 5rem;
  }

  .footer-inner {
    align-items: center;
    display: flex;
    gap: 1.5rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 72rem;
    min-height: 8rem;
    padding: 1.25rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .footer-nav a {
    border: 1px solid var(--inverse-line);
    border-radius: 8px;
    color: var(--inverse-muted);
    font-size: 0.82rem;
    padding: 0.45rem 0.65rem;
    text-decoration: none;
  }

  .footer-nav a:hover {
    background: var(--inverse-ink);
    color: var(--inverse);
  }

  .footer-email {
    color: var(--inverse-ink);
    font-family: "CabinetGrotesk", sans-serif;
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .site-footer {
      margin-top: 3rem;
    }

    .footer-inner {
      align-items: flex-start;
      flex-direction: column-reverse;
      gap: 1rem;
      min-height: auto;
      padding: 1.25rem 1rem;
    }

    .footer-nav {
      width: 100%;
    }

    .footer-nav a {
      align-items: center;
      display: inline-flex;
      min-height: 2.5rem;
    }

    .footer-email {
      font-size: clamp(1.1rem, 6vw, 1.45rem);
      line-height: 1.15;
      white-space: normal;
      word-break: break-word;
    }
  }
</style>
