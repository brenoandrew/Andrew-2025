---
import BasicLayout from "./BasicLayout.astro";

interface Props {
  title: string;
  description: string;
  page?: "travel" | "blog" | "blog-post" | "photography";
  image?: string;
}

const { title, description, page, image } = Astro.props;
---

<BasicLayout description={description} image={image} page={page} title={title}>
  <slot />
</BasicLayout>
