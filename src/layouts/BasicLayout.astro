---
import { profile } from "../lib/profile";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description: string;
  page?: "travel" | "blog" | "blog-post" | "photography";
  slug?: string | undefined;
  pubDate?: string | Date;
  image?: string;
}

const { title, description, page, slug, pubDate, image } = Astro.props;
const defaultImage = page === "travel" ? "/globe_preview.png" : "/og-image.png";
const imagePath = image || defaultImage;
const imageUrl = imagePath.startsWith("http")
  ? imagePath
  : `${Astro.url.origin}${imagePath}`;
const canonicalUrl = slug
  ? new URL(slug.startsWith("/") ? slug : `/${slug}`, Astro.url.origin).href
  : Astro.url.href;
const ogType = page === "blog-post" ? "article" : "website";

const schema =
  page !== "blog-post"
    ? {
        "@context": "https://schema.org",
        "@type": "Person",
        name: profile.name,
        url: Astro.url.origin,
        sameAs: profile.sameAs,
        image: `${Astro.url.origin}/og-image.png`,
        jobTitle: profile.shortRole,
        worksFor: {
          "@type": "Organization",
          name: profile.companyName,
          url: profile.companyUrl,
          address: {
            "@type": "PostalAddress",
            addressLocality: profile.location,
            addressCountry: "KR",
          },
        },
        nationality: {
          "@type": "Country",
          name: profile.origin,
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalUrl,
        },
        headline: title,
        description: description || title,
        image: imageUrl,
        author: {
          "@type": "Person",
          name: profile.name,
          url: Astro.url.origin,
          sameAs: profile.sameAs,
        },
        publisher: {
          "@type": "Organization",
          name: profile.name,
          logo: {
            "@type": "ImageObject",
            url: `${Astro.url.origin}/og-image.png`,
          },
        },
        datePublished: pubDate || new Date().toISOString(),
        dateModified: pubDate || new Date().toISOString(),
      };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width" name="viewport" />
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <meta content={Astro.generator} name="generator" />
    <title>{title}</title>
    <meta content={description} name="description" />
    <meta content="index, follow" name="robots" />
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={ogType} property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content={imageUrl} property="og:image" />
    <meta content="#f4f1eb" id="theme-color-meta" name="theme-color" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content={imageUrl} name="twitter:image" />

    <link href={canonicalUrl} rel="canonical" />
    <script
      is:inline
      set:html={JSON.stringify(schema)}
      type="application/ld+json"
    />
    <script is:inline>
      (() => {
        const lightColor = "#f4f1eb";
        const darkColor = "#101010";

        const resolveTheme = () => {
          try {
            const storedTheme = localStorage.getItem("theme");
            if (storedTheme === "light" || storedTheme === "dark") {
              return storedTheme;
            }
          } catch {
            // Ignore storage access failures and fall back to the system theme.
          }

          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        };

        const theme = resolveTheme();
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;

        const themeColor = document.querySelector("#theme-color-meta");
        if (themeColor) {
          themeColor.setAttribute(
            "content",
            theme === "dark" ? darkColor : lightColor
          );
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <slot name="loader" />
    <slot />
    <SiteFooter />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --paper: #f4f1eb;
    --paper-soft: #ebe7df;
    --surface: #ffffff;
    --surface-soft: #f8f6f1;
    --surface-hover: #ffffff;
    --ink: #151515;
    --ink-muted: #5f5b54;
    --line: rgba(21, 21, 21, 0.12);
    --line-strong: rgba(21, 21, 21, 0.24);
    --inverse: #171717;
    --inverse-ink: #f8f6f1;
    --inverse-muted: #d8d4cc;
    --inverse-line: rgba(248, 246, 241, 0.12);
    --header-bg: #f4f1eb;
    --toggle-track: #f4f1eb;
    --toggle-border: rgba(21, 21, 21, 0.28);
    --toggle-thumb: #151515;
    --toggle-thumb-ring: rgba(21, 21, 21, 0.12);
    --on-ink: #ffffff;
    --globe-ocean: #ffffff;
    --globe-land: #f8f6f1;
    --globe-visited: #151515;
    --globe-line: #151515;
    --media-filter: none;
    --accent: #d96f4d;
    --sage: #aeb8aa;
    --radius: 8px;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --paper: #101010;
    --paper-soft: #171717;
    --surface: #1d1d1d;
    --surface-soft: #151515;
    --surface-hover: #242424;
    --ink: #f4f1eb;
    --ink-muted: #b7b0a5;
    --line: rgba(244, 241, 235, 0.13);
    --line-strong: rgba(244, 241, 235, 0.28);
    --inverse: #050505;
    --inverse-ink: #f4f1eb;
    --inverse-muted: #b7b0a5;
    --inverse-line: rgba(244, 241, 235, 0.16);
    --header-bg: #101010;
    --toggle-track: #101010;
    --toggle-border: rgba(244, 241, 235, 0.32);
    --toggle-thumb: #f4f1eb;
    --toggle-thumb-ring: rgba(244, 241, 235, 0.14);
    --on-ink: #101010;
    --globe-ocean: #1d1d1d;
    --globe-land: #101010;
    --globe-visited: #f4f1eb;
    --globe-line: #b7b0a5;
    --media-filter: brightness(0.78) contrast(1.08) saturate(0.82);
  }

  @font-face {
    font-family: "CabinetGrotesk";
    src: url("/fonts/CabinetGrotesk-Variable.ttf") format("truetype-variations");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
    font-weight: 100 1000;
  }
  @font-face {
    font-family: "Satoshi";
    src: url("/fonts/Satoshi-Variable.ttf") format("truetype-variations");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
    font-weight: 100 1000;
  }

  body {
    background: var(--paper);
    color: var(--ink);
    margin: 0;
    font-family: "Satoshi", sans-serif;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    overflow-x: hidden;
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  html {
    overflow-x: hidden;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    min-width: 0;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "CabinetGrotesk", sans-serif;
    max-width: 100%;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  p {
    font-family: "Satoshi";
    max-width: 100%;
    overflow-wrap: break-word;
  }

  b {
    font-weight: 700 !important;
  }

  a {
    color: inherit;
    overflow-wrap: anywhere;
  }

  img,
  svg,
  canvas,
  video {
    max-width: 100%;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 4px;
  }

  .skip-link {
    background: var(--ink);
    border-radius: 8px;
    color: var(--paper);
    left: 1rem;
    padding: 0.65rem 0.9rem;
    position: fixed;
    top: 1rem;
    transform: translateY(-150%);
    transition: transform 160ms ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
